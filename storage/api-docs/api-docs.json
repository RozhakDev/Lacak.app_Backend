        "/api/v1/jobs/{id}/apply": {
            "post": {
                "tags": [
                    "Job Vacancy"
                ],
                "summary": "Kirim Ajuan Lamaran Kerja",
                "description": "Mendaftarkan aplikasi partisipasi pada sebuah lowongan. Menggunakan payload formulir untuk mengakomodasi pengunggahan berkas lamaran.",
                "operationId": "afaf33124918cc35338d31d1e9872b8d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "cv": {
                                        "description": "Berkas Curiculum Vitae (PDF/DOCX), max 5MB",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "cover_letter": {
                                        "description": "Surat pengantar lamaran (Opsional)",
                                        "type": "string",
                                        "example": "Yth. HRD Manager, bersama ini saya sampaikan..."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Aplikasi lamaran sukses terekam dalam pangkalan data."
                    },
                    "400": {
                        "description": "Penolakan sistem karena alumni telah melakukan aplikasi sebelumnya pada loker ini."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/events": {
            "get": {
                "tags": [
