{
    "openapi": "3.0.0",
    "info": {
        "title": "Lacak.app API Documentation",
        "description": "Dokumentasi REST API untuk Lacak.app Backend",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "API Server"
        }
    ],
    "paths": {
        "/api/health": {
            "get": {
                "tags": [
                    "System"
                ],
                "summary": "Pemeriksaan Kesehatan API",
                "description": "Mengembalikan status operasional API Lacak.app beserta informasi runtime yang digunakan untuk pemantauan layanan, diagnosis sistem, dan verifikasi ketersediaan API.",
                "operationId": "da6d191bd3c165491ca6dbec524e15f1",
                "responses": {
                    "200": {
                        "description": "API berhasil berjalan dan siap menerima permintaan."
                    }
                }
            }
        },
        "/api/v1/auth/register": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Pendaftaran Akun Alumni",
                "description": "Mendaftarkan entitas akun baru khusus untuk pengguna (Alumni). Sistem akan melakukan validasi unik pada NISN dan Email, lalu men-generate OTP untuk aktivasi.",
                "operationId": "87dab0081accee0c15b52cf5c08637c1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "nisn",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Ahmad Budi Santoso"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "alumni@smk-contoh.sch.id"
                                    },
                                    "nisn": {
                                        "type": "string",
                                        "example": "0011223344"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "Secret123!"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "Secret123!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Pendaftaran berhasil, sistem mengirimkan kode OTP ke email."
                    },
                    "422": {
                        "description": "Gagal validasi struktur payload."
                    }
                }
            }
        },
        "/api/v1/auth/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Otentikasi Pengguna (Login)",
                "description": "Melakukan verifikasi kredensial pengguna (NISN atau Email). Mengembalikan token Bearer Sanctum yang akan digunakan untuk seluruh akses terproteksi.",
                "operationId": "5a244c4832152d5c9bcaafa1d96cedf6",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "identifier",
                                    "password"
                                ],
                                "properties": {
                                    "identifier": {
                                        "description": "Bisa menggunakan Email atau NISN",
                                        "type": "string",
                                        "example": "alumni@smk-contoh.sch.id"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "Secret123!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Otentikasi berhasil. Token diberikan."
                    },
                    "401": {
                        "description": "Kredensial tidak valid."
                    },
                    "403": {
                        "description": "Akun belum diverifikasi OTP."
                    }
                }
            }
        },
        "/api/v1/auth/verify-email": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Verifikasi Kode OTP Email",
                "description": "Memverifikasi token OTP 6 digit yang dikirimkan ke email alumni pada saat pendaftaran awal.",
                "operationId": "12f22b12ce73c87b4f9abe2eeee81561",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "otp"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "alumni@smk-contoh.sch.id"
                                    },
                                    "otp": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Email berhasil diverifikasi, status akun menjadi aktif."
                    },
                    "400": {
                        "description": "OTP salah atau kedaluwarsa."
                    }
                }
            }
        },
        "/api/v1/auth/resend-otp": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Kirim Ulang OTP",
                "description": "Meminta sistem untuk men-generate ulang dan mengirimkan OTP baru ke email pengguna (berlaku untuk konteks verifikasi atau reset password).",
                "operationId": "366f6c3436f7f5e7bd535674bb97f7f6",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "context"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "alumni@smk-contoh.sch.id"
                                    },
                                    "context": {
                                        "type": "string",
                                        "example": "verify",
                                        "enum": [
                                            "verify",
                                            "reset"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP baru berhasil diterbitkan dan dikirim."
                    }
                }
            }
        },
        "/api/v1/auth/forgot-password": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Lupa Kata Sandi (Permintaan OTP)",
                "description": "Menginisiasi alur pemulihan akun. Sistem mengirimkan kode OTP khusus ke email pengguna yang terdaftar.",
                "operationId": "95901a460f6d5285b590d6ebbf749c5a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "alumni@smk-contoh.sch.id"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Instruksi pemulihan berhasil dikirim."
                    }
                }
            }
        },
        "/api/v1/auth/reset-password": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Pemulihan Kata Sandi (Reset)",
                "description": "Mengganti kata sandi lama dengan yang baru. Memerlukan kode OTP sah dari alur Lupa Kata Sandi.",
                "operationId": "daae83dfa2ab4bbac43d4fff2730b238",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "otp",
                                    "new_password",
                                    "new_password_confirmation"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "alumni@smk-contoh.sch.id"
                                    },
                                    "otp": {
                                        "type": "string",
                                        "example": "123456"
                                    },
                                    "new_password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "NewSecret123!"
                                    },
                                    "new_password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "NewSecret123!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Kata sandi berhasil diperbarui."
                    }
                }
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Akhiri Sesi (Logout)",
                "description": "Menghapus dan menonaktifkan token akses Bearer saat ini sehingga tidak dapat digunakan kembali.",
                "operationId": "dbcbbb751ffb19ad3436a39af0c209e5",
                "responses": {
                    "200": {
                        "description": "Sesi berhasil diakhiri."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/profile": {
            "get": {
                "tags": [
                    "Alumni Profile"
                ],
                "summary": "Lihat Profil Alumni Saat Ini",
                "description": "Mengambil data profil lengkap dari alumni yang sedang terotentikasi, beserta relasi portofolio dan riwayat pengalaman.",
                "operationId": "c7a30577447ddf288ad0fba90b452755",
                "responses": {
                    "200": {
                        "description": "Payload data profil sukses diambil."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Alumni Profile"
                ],
                "summary": "Perbarui Data Profil Alumni",
                "description": "Melakukan pembaruan terhadap atribut profil alumni. Menggunakan Content-Type multipart/form-data untuk memfasilitasi unggahan Avatar dan Dokumen Resume (CV).",
                "operationId": "7255f83a771d63d78180bd7ed09ba784",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "major_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "graduation_year": {
                                        "type": "integer",
                                        "example": 2024
                                    },
                                    "phone_number": {
                                        "type": "string",
                                        "example": "08123456789"
                                    },
                                    "avatar": {
                                        "description": "Berkas gambar (JPG/PNG/WEBP), max 2MB",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "resume": {
                                        "description": "Berkas dokumen (PDF), max 5MB",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "about_me": {
                                        "type": "string",
                                        "example": "Seorang software engineer..."
                                    },
                                    "skills[0]": {
                                        "type": "string",
                                        "example": "PHP"
                                    },
                                    "skills[1]": {
                                        "type": "string",
                                        "example": "React"
                                    },
                                    "linkedin_url": {
                                        "type": "string",
                                        "example": "https://linkedin.com/in/alumni"
                                    },
                                    "portfolio_url": {
                                        "type": "string",
                                        "example": "https://alumni.dev"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Data profil berhasil disinkronisasi."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/profile/experiences": {
            "post": {
                "tags": [
                    "Alumni Experience"
                ],
                "summary": "Tambahkan Pengalaman Baru",
                "description": "Mendaftarkan rekam jejak pengalaman kerja, organisasi, atau sertifikasi ke dalam profil alumni.",
                "operationId": "9aa64fd8744cb2260a99318a4e830aa2",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "company_name",
                                    "position",
                                    "start_date"
                                ],
                                "properties": {
                                    "company_name": {
                                        "type": "string",
                                        "example": "PT Teknologi Bangsa"
                                    },
                                    "position": {
                                        "type": "string",
                                        "example": "Backend Developer"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Mengembangkan arsitektur microservices..."
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2023-01-15"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-01-15"
                                    },
                                    "is_current": {
                                        "type": "boolean",
                                        "example": false
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Pengalaman baru direkam."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
